CROPS = {
    "met":          (545, 690, 650, 755),   # 02:02:32
    "velocity":     (635, 690, 725, 755),   # 3,188
    "dist_earth":   (720, 690, 810, 755),   # 127,703
    "dist_moon":    (805, 690, 895, 755),   # 142,396
}

def ocr_arow():
    with sync_playwright() as p:
        browser = p.chromium.launch()
        page = browser.new_page(viewport={"width": 1456, "height": 816})
        page.goto("https://www.nasa.gov/missions/artemis-ii/arow/")
        page.wait_for_timeout(25000)  # Wait for Unity to boot + render live data

        screenshot = page.screenshot()
        img = Image.open(io.BytesIO(screenshot))

        results = {}
        for key, box in CROPS.items():
            crop = img.crop(box)
            # Upscale + threshold for better OCR on white-on-dark
            crop = crop.resize((crop.width*3, crop.height*3), Image.LANCZOS)
            text = pytesseract.image_to_string(
                crop,
                config='--psm 7 -c tessedit_char_whitelist=0123456789:,.'
            ).strip()
            results[key] = text
            print(f"{key}: {text}")

        browser.close()
        return results

# Poll every 5 minutes
import time
while True:
    data = ocr_arow()
    print(data)
    time.sleep(300)


Reliability: High for the four displayed values — the contrast is excellent (white digits on dark background, large font). The fixed HUD layout means coordinates won’t shift between polls.
What you get: MET, velocity (MPH), distance from Earth (miles), distance to Moon (miles) — exactly the four numbers AROW shows, at whatever cadence you poll.

